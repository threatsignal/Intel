# Telegram API Credentials (get from https://my.telegram.org)
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Gemini API Key for LLM translation and summarization
GEMINI_API_KEY=your_gemini_api_key_here

# Discord Webhook URL for alerting
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Comma-separated list of Telegram channel names or IDs to monitor
TARGET_CHANNELS=cve_updates,exploit_alerts,threat_intel_feed
